{
  "name": "@pageaudit/scraper",
  "version": "1.0.0",
  "description": "Puppeteer scraping service for PageAudit",
  "main": "index.ts",
  "scripts": {
    "start": "tsx index.ts",
    "dev": "tsx watch index.ts",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "node src/test.js",
    "db:generate": "prisma generate",
