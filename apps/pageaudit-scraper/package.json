    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.10.1",
    "openai": "^6.33.0",
    "puppeteer": "^24.40.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "nodemon": "^3.0.2",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
