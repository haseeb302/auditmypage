{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "noEmit": true
  },
  "include": [
    "index.ts",
    "logger.ts",
    "error.ts",
    "routes.ts",
    "lib/**/*.ts",
    "service/**/*.ts"
  ],
  "exclude": ["node_modules", "tests"]
}
