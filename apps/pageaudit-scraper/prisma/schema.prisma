// PageAudit — PostgreSQL (e.g. Railway).
// Prisma ORM 6 (`prisma-client-js`). Upgrade to Prisma 7 + prisma.config.ts when on Node 20.19+ / 22+.
// `result` stores the full shareable audit payload (AuditResult-shaped JSON).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A completed landing-page audit, retrievable by `id` for share links (e.g. /audit/:id).
model PageAudit {
  id String @id @default(cuid())

  /// Normalised URL that was audited (same idea as the audit result’s `url`).
  sourceUrl String @map("source_url")

  /// Full scored report as JSON: { url, score, scanned_at, dimensions: [...] }.
  /// Kept as Json so the UI schema can evolve without a migration for every field.
  result Json @map("result")

  /// Optional raw scrape payload for debugging, re-runs, or future features.
  pageData Json? @map("page_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sourceUrl])
  @@index([createdAt(sort: Desc)])
  @@map("page_audits")
}
